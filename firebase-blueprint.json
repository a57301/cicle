{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User's personal information and cycle settings.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "displayName": { "type": "string", "description": "User's display name" },
        "email": { "type": "string", "format": "email", "description": "User's email" },
        "cycleLength": { "type": "number", "description": "Average cycle length in days" },
        "periodDuration": { "type": "number", "description": "Average period duration in days" },
        "lastPeriodDate": { "type": "string", "format": "date", "description": "Start date of the last period" },
        "onboardingComplete": { "type": "boolean", "description": "Whether the user has completed the onboarding wizard" },
        "language": { "type": "string", "enum": ["en", "es"] },
        "dietaryRestrictions": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "email", "cycleLength", "periodDuration", "lastPeriodDate"]
    },
    "DailyLog": {
      "title": "Daily Log",
      "description": "User's daily symptoms, mood, and flow tracking.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Owner's UID" },
        "date": { "type": "string", "format": "date", "description": "Date of the log (YYYY-MM-DD)" },
        "flowIntensity": { "type": "string", "enum": ["none", "spotting", "light", "medium", "heavy"] },
        "physicalSymptoms": { "type": "array", "items": { "type": "string" }, "description": "List of physical symptoms (e.g., cramps, bloating)" },
        "moods": { "type": "array", "items": { "type": "string" }, "description": "List of moods/emotions" },
        "energyLevel": { "type": "number", "description": "Energy level from 1 to 5" },
        "notes": { "type": "string", "description": "Optional notes" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "date"]
    },
    "CycleHistory": {
      "title": "Cycle History",
      "description": "Historical data of completed cycles.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Owner's UID" },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "duration": { "type": "number" },
        "periodDuration": { "type": "number" }
      },
      "required": ["uid", "startDate", "endDate", "duration"]
    },
    "DailyContent": {
      "title": "Daily Content",
      "description": "Cached AI recommendations and insights for a specific day.",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date" },
        "insights": { "type": "object" },
        "dietPlan": { "type": "object" },
        "lunarRecs": { "type": "object" }
      },
      "required": ["date"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "User profile document"
    },
    "/users/{uid}/daily_logs/{date}": {
      "schema": "DailyLog",
      "description": "Daily logs for a specific user"
    },
    "/users/{uid}/cycles/{cycleId}": {
      "schema": "CycleHistory",
      "description": "Historical cycles for a specific user"
    },
    "/users/{uid}/daily_content/{date}": {
      "schema": "DailyContent",
      "description": "Cached AI content for the day"
    }
  }
}
